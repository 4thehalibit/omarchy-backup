source = ~/.config/omarchy/current/theme/hyprlock.conf

general {
    ignore_empty_input = true
}

background {
    monitor =
    color = $color
    path = ~/.config/omarchy/current/background
    blur_passes = 3
}

animations {
    enabled = true
    fade_in = true
    fade_out = true
}

# Clock
label {
    monitor =
    text = $TIME
    font_size = 96
    font_family = CaskaydiaMono Nerd Font
    color = $font_color
    position = 0, 160
    halign = center
    valign = center
    shadow_passes = 2
    shadow_size = 4
}

# Date
label {
    monitor =
    text = cmd[update:60000] date "+%A, %B %d"
    font_size = 24
    font_family = CaskaydiaMono Nerd Font
    color = $font_color
    position = 0, 60
    halign = center
    valign = center
    shadow_passes = 2
    shadow_size = 4
}

# Weather
label {
    monitor =
    text = cmd[update:1800000] curl -sf "wttr.in/?format=%l:+%C+%t"
    font_size = 20
    font_family = CaskaydiaMono Nerd Font
    color = $font_color
    position = 0, 20
    halign = center
    valign = center
    shadow_passes = 2
    shadow_size = 4
}

input-field {
    monitor =
    size = 650, 100
    position = 0, -120
    halign = center
    valign = center

    inner_color = $inner_color
    outer_color = $outer_color
    outline_thickness = 4

    font_family = CaskaydiaMono Nerd Font
    font_color = $font_color

    placeholder_text = <span> Enter Password 󰈷 </span>
    check_color = $check_color
    fail_text = <i>$FAIL ($ATTEMPTS)</i>

    rounding = 16
    shadow_passes = 0
    fade_on_empty = false
}

auth {
    fingerprint:enabled = true
}
