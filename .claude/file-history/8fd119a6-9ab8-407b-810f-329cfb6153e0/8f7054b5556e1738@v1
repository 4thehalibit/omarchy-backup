services:
  windows:
    image: dockurr/windows
    container_name: omarchy-windows
    environment:
      VERSION: "11"
      RAM_SIZE: "32G"
      CPU_CORES: "12"
      DISK_SIZE: "64G"
      GPU: "qxl"
      VM_NET_DEV: "eth0"
      USERNAME: "vwestberg"
      PASSWORD: "West11berg"
    devices:
      - /dev/kvm
      - /dev/net/tun
    cap_add:
      - NET_ADMIN
    ports:
      - 8006:8006
      - 3389:3389/tcp
      - 3389:3389/udp
    volumes:
      - /lib/modules:/lib/modules:ro
      - /home/vwestberg/.windows:/storage
      - /home/vwestberg/Windows:/shared
    restart: always
    stop_grace_period: 2m
