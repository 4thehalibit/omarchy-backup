services:
  windows:
    image: dockurr/windows
    container_name: omarchy-windows
    environment:
      VERSION: "11"
      RAM_SIZE: "16G"
      CPU_CORES: "2"
      DISK_SIZE: "128G"
      USERNAME: "vwestberg"
      PASSWORD: "West11berg1!"
      TZ: "America/Chicago"
      ARGUMENTS: "-rtc base=localtime,clock=host,driftfix=slew"
    devices:
      - /dev/kvm
      - /dev/net/tun
    cap_add:
      - NET_ADMIN
    ports:
      - 127.0.0.1:8006:8006
      - 127.0.0.1:3389:3389/tcp
      - 127.0.0.1:3389:3389/udp
    volumes:
      - /home/vwestberg/.windows:/storage
      - /home/vwestberg/Windows:/shared
    restart: unless-stopped
    stop_grace_period: 2m
